# ===========================================
# SINERGIL AUT - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control!

# ---------------------------
# Supabase (Required)
# ---------------------------
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------
# App Config
# ---------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SinergiLaut

# ---------------------------
# Supabase Storage
# ---------------------------
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=sinergil aut-assets

# ---------------------------
# Analytics (Optional)
# ---------------------------
# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# ---------------------------
# Email (Optional - Supabase handles auth emails by default)
# ---------------------------
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@sinergil aut.id

# ---------------------------
# Payment Gateway (Placeholder)
# ---------------------------
# NEXT_PUBLIC_PAYMENT_GATEWAY_KEY=your-payment-gateway-key
# PAYMENT_GATEWAY_SECRET=your-payment-gateway-secret
