# ===========================================
# SINERGILAUT - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control!

# ---------------------------
# Supabase (Required)
# ---------------------------
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database connections for Prisma
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/database
DATABASE_URL="postgres://postgres.[your-project-id]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://postgres.[your-project-id]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ---------------------------
# App Config
# ---------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SinergiLaut

# ---------------------------
# Supabase Storage
# ---------------------------
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=sinergilaut-assets

# ---------------------------
# Midtrans Payment Gateway (Required for Donations)
# ---------------------------
# Daftarkan akun di: https://dashboard.midtrans.com (production)
# atau: https://dashboard.sandbox.midtrans.com (sandbox/testing)
#
# PENTING: Daftarkan Notification URL di Midtrans Dashboard:
#   Pengaturan → Konfigurasi Pembayaran → Notification URL
#   Isi dengan: https://yourdomain.com/api/midtrans/webhook
#
# Server Key: https://dashboard.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
#
# Client Key (digunakan di frontend untuk Snap.js):
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
#
# Mode: "false" = sandbox (testing), "true" = production
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# ---------------------------
# Analytics (Optional)
# ---------------------------
# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ---------------------------
# Email (Optional - Supabase handles auth emails by default)
# ---------------------------
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@sinergilaut.id
NEXT_PUBLIC_MAPTILER_KEY=your_key_here